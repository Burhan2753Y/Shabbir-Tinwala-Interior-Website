---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Work With Me - Process & Pricing"
  description="Learn about our 4-step interior design process, core services, and book a consultation for your Mumbai home."
>
  <!-- Page Header -->
  <section class="bg-secondary py-20 md:py-28 pt-32">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1
        class="text-4xl md:text-5xl font-bold text-primary mb-6 tracking-tight"
      >
        Work With Me
      </h1>
      <p class="text-xl text-gray-600 font-light leading-relaxed">
        A structured, transparent approach to transforming your space. No hidden
        agency fees, just clear communication and quality execution.
      </p>
    </div>
  </section>

  <!-- Section 1: The 4-Step Design Process -->
  <section class="py-24 bg-gray-50 relative border-b border-gray-100">
    <div
      class="absolute inset-0 opacity-[0.03]"
      style="background-image: radial-gradient(#000 1px, transparent 1px); background-size: 32px 32px;"
    >
    </div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-primary mb-4">The 4-Step Process</h2>
        <p class="text-gray-500 font-light max-w-2xl mx-auto">
          From our first conversation to the moment you step into your finished
          home, here is exactly what to expect.
        </p>
      </div>

      <div class="relative max-w-5xl mx-auto">
        <!-- Connecting Line -->
        <div
          class="hidden md:block absolute top-12 left-0 w-full h-0.5 bg-gray-100 z-0"
        >
        </div>

        <div class="grid md:grid-cols-4 gap-12 relative z-10">
          <div class="text-center">
            <div
              class="w-24 h-24 mx-auto bg-white border-4 border-gray-100 rounded-full flex items-center justify-center text-2xl font-bold text-accent mb-6 shadow-sm"
            >
              1
            </div>
            <h3 class="text-xl font-bold text-primary mb-3">Consultation</h3>
            <p class="text-gray-600 font-light text-sm leading-relaxed">
              We discuss your lifestyle, aesthetic preferences, functional
              needs, and set realistic budget expectations on site.
            </p>
          </div>

          <div class="text-center">
            <div
              class="w-24 h-24 mx-auto bg-white border-4 border-gray-100 rounded-full flex items-center justify-center text-2xl font-bold text-accent mb-6 shadow-sm"
            >
              2
            </div>
            <h3 class="text-xl font-bold text-primary mb-3">2D/3D Layouts</h3>
            <p class="text-gray-600 font-light text-sm leading-relaxed">
              Development of highly optimized floor plans followed by
              photorealistic 3D renders so you know exactly what you're getting.
            </p>
          </div>

          <div class="text-center">
            <div
              class="w-24 h-24 mx-auto bg-white border-4 border-gray-100 rounded-full flex items-center justify-center text-2xl font-bold text-accent mb-6 shadow-sm"
            >
              3
            </div>
            <h3 class="text-xl font-bold text-primary mb-3">
              Material Selection
            </h3>
            <p class="text-gray-600 font-light text-sm leading-relaxed">
              Guided visits to premium vendors to select laminates, veneers,
              fabrics, and hardware that fit your budget.
            </p>
          </div>

          <div class="text-center">
            <div
              class="w-24 h-24 mx-auto bg-accent border-4 border-accent-hover rounded-full flex items-center justify-center text-2xl font-bold text-white mb-6 shadow-md"
            >
              4
            </div>
            <h3 class="text-xl font-bold text-primary mb-3">Site Execution</h3>
            <p class="text-gray-600 font-light text-sm leading-relaxed">
              I personally oversee my trusted team of carpenters, electricians,
              and painters to ensure flawless execution.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 3: Contact Form -->
  <section
    class="py-24 bg-gradient-to-b from-white to-gray-50 relative"
    id="booking"
  >
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div
        class="bg-white rounded-3xl shadow-2xl overflow-hidden border border-gray-100"
      >
        <div class="bg-primary px-8 py-10 text-center">
          <h2 class="text-3xl font-bold text-white mb-2">Get in Touch</h2>
          <p class="text-gray-300 font-light">
            Tell me a bit about your space and I'll get back to you within 24
            hours.
          </p>
        </div>

        <div id="success-msg" class="p-8 md:p-12 pb-0" style="display: none;">
          <div class="bg-green-50 text-green-800 rounded-lg p-6 text-center border border-green-100">
            <h3 class="text-xl font-bold mb-2">Thank you!</h3>
            <p>Your inquiry has been received. I'll get back to you within 24 hours.</p>
          </div>
        </div>
        <div id="error-msg" class="p-8 md:p-12 pb-0" style="display: none;">
          <div class="bg-red-50 text-red-800 rounded-lg p-4 text-center border border-red-100">
            Oops! There was a problem submitting your form.
          </div>
        </div>

        <form id="contact-form" class="p-8 md:p-12">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
            <div>
              <label for="name" class="block text-sm font-medium text-gray-700 mb-2">Full Name</label>
              <input type="text" id="name" name="name" required class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:ring-2 focus:ring-accent focus:border-accent outline-none transition-colors" placeholder="John Doe" />
            </div>
            <div>
              <label for="location" class="block text-sm font-medium text-gray-700 mb-2">Location (Area in Mumbai)</label>
              <input type="text" id="location" name="location" required class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:ring-2 focus:ring-accent focus:border-accent outline-none transition-colors" placeholder="e.g. Andheri West" />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-2">Email Address</label>
              <input type="email" id="email" name="email" required class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:ring-2 focus:ring-accent focus:border-accent outline-none transition-colors" placeholder="john@example.com" />
            </div>
            <div>
              <label for="phone" class="block text-sm font-medium text-gray-700 mb-2">Phone Number</label>
              <input type="tel" id="phone" name="phone" required class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:ring-2 focus:ring-accent focus:border-accent outline-none transition-colors" placeholder="+91 98765 43210" />
            </div>
          </div>

          <div class="mb-6">
            <label for="scope" class="block text-sm font-medium text-gray-700 mb-2">Project Scope</label>
            <select id="scope" name="scope" required class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:ring-2 focus:ring-accent focus:border-accent outline-none transition-colors appearance-none bg-white">
              <option value="" disabled selected>Select the scope of work...</option>
              <option value="full">Full Home (Turnkey)</option>
              <option value="consultation">Design Consultation Only</option>
              <option value="modular">Specific Rooms / Modular Overhaul</option>
            </select>
          </div>

          <div class="mb-8">
            <label for="budget" class="block text-sm font-medium text-gray-700 mb-2">Estimated Budget Range</label>
            <select id="budget" name="budget" required class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:ring-2 focus:ring-accent focus:border-accent outline-none transition-colors appearance-none bg-white">
              <option value="" disabled selected>Select a budget range...</option>
              <option value="under5L">Under ₹5 Lakhs</option>
              <option value="5to15L">₹5 Lakhs - ₹15 Lakhs</option>
              <option value="15to30L">₹15 Lakhs - ₹30 Lakhs</option>
              <option value="30Lplus">₹30 Lakhs+</option>
            </select>
          </div>

          <div class="mb-8">
            <label for="details" class="block text-sm font-medium text-gray-700 mb-2">Additional Details (Optional)</label>
            <textarea id="details" name="details" rows="3" class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:ring-2 focus:ring-accent focus:border-accent outline-none transition-colors resize-none" placeholder="Any specific requirements or timelines?"></textarea>
          </div>

          <button id="submit-btn" type="submit" class="w-full bg-accent hover:bg-accent-hover text-white font-bold py-4 rounded-lg transition-colors shadow-lg shadow-accent/30 disabled:opacity-70 disabled:cursor-not-allowed">
            Submit Inquiry
          </button>
        </form>

        <script is:inline>
          document.addEventListener('DOMContentLoaded', () => {
            const form = document.getElementById('contact-form');
            const successMsg = document.getElementById('success-msg');
            const errorMsg = document.getElementById('error-msg');
            const submitBtn = document.getElementById('submit-btn');

            form.addEventListener('submit', async (e) => {
              e.preventDefault();
              
              submitBtn.disabled = true;
              submitBtn.innerText = 'Sending...';
              successMsg.style.display = 'none';
              errorMsg.style.display = 'none';

              const formData = new FormData(form);
              const data = Object.fromEntries(formData.entries());

              try {
                const response = await fetch('https://formspree.io/f/mzdwlaqv', {
                  method: 'POST',
                  headers: {
                    'Accept': 'application/json',
                    'Content-Type': 'application/json'
                  },
                  body: JSON.stringify(data)
                });

                if (response.ok) {
                  successMsg.style.display = 'block';
                  form.reset();
                } else {
                  errorMsg.style.display = 'block';
                }
              } catch (error) {
                errorMsg.style.display = 'block';
              } finally {
                submitBtn.disabled = false;
                submitBtn.innerText = 'Submit Inquiry';
              }
            });
          });
        </script>
      </div>
    </div>
  </section>
</Layout>
