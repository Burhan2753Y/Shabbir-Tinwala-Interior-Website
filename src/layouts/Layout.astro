---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Personalized Residential Interior Design in Mumbai — Crafting functional, beautiful spaces without the agency markup.",
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Shabbir Tinwala Interior Design</title>
  </head>
  <body
    class="bg-secondary text-primary font-sans antialiased min-h-screen flex flex-col"
  >
    <!-- Navigation -->
    <header
      class="fixed w-full top-0 z-50 bg-white/80 backdrop-blur-md border-b border-gray-100 transition-all duration-300"
    >
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-20">
          <!-- Logo -->
          <a href="/" class="flex-shrink-0 flex items-center group">
            <div class="text-2xl font-bold tracking-tighter">
              <span
                class="text-primary group-hover:text-accent transition-colors"
                >Shabbir Tinwala</span
              >
              <span class="text-gray-400 font-light"> Interiors</span>
            </div>
          </a>

          <!-- Desktop Menu -->
          <nav class="hidden md:flex space-x-10">
            <a
              href="/"
              class="text-base font-medium text-gray-700 hover:text-accent transition-colors"
              >Home</a
            >
            <a
              href="/spaces"
              class="text-base font-medium text-gray-700 hover:text-accent transition-colors"
              >Spaces</a
            >
            <a
              href="/work-with-me"
              class="text-base font-medium text-gray-700 hover:text-accent transition-colors"
              >Work With Me</a
            >
          </nav>

          <!-- Mobile Menu Button -->
          <div class="md:hidden flex items-center">
            <button
              id="mobile-menu-btn"
              class="text-gray-700 hover:text-accent focus:outline-none"
            >
              <svg
                class="h-6 w-6"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M4 6h16M4 12h16M4 18h16"></path>
              </svg>
            </button>
          </div>
        </div>
      </div>

      <!-- Mobile Menu Panel -->
      <div
        id="mobile-menu"
        class="hidden md:hidden bg-white border-t border-gray-100 shadow-lg"
      >
        <div class="px-2 pt-2 pb-3 space-y-1 sm:px-3">
          <a
            href="/"
            class="block px-3 py-2 rounded-md text-base font-medium text-gray-900 hover:bg-gray-50 hover:text-accent"
            >Home</a
          >
          <a
            href="/spaces"
            class="block px-3 py-2 rounded-md text-base font-medium text-gray-900 hover:bg-gray-50 hover:text-accent"
            >Spaces</a
          >
          <a
            href="/work-with-me"
            class="block px-3 py-2 rounded-md text-base font-medium text-gray-900 hover:bg-gray-50 hover:text-accent"
            >Work With Me</a
          >
        </div>
      </div>
    </header>

    <main class="flex-grow pt-20">
      <slot />
    </main>

    <!-- Lightbox Modal -->
    <div
      id="lightbox"
      class="fixed inset-0 z-[100] hidden bg-black/95 items-center justify-center p-4 opacity-0 transition-opacity duration-300"
    >
      <button
        id="lightbox-close"
        class="absolute top-6 right-6 text-white hover:text-accent focus:outline-none z-10 transition-transform hover:scale-110"
      >
        <svg
          class="h-10 w-10"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
      <img
        id="lightbox-img"
        src=""
        alt="Fullscreen image"
        class="max-w-full max-h-full object-contain rounded-lg shadow-2xl transform scale-95 transition-transform duration-300"
      />
    </div>

    <!-- Footer -->
    <footer class="bg-primary text-white py-12 mt-auto">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div>
            <h3 class="text-2xl font-bold tracking-tighter mb-4">
              <span class="text-white">Shabbir Tinwala</span>
              <span class="text-gray-400 font-light"> Interiors</span>
            </h3>
            <p class="text-gray-400 max-w-xs text-sm leading-relaxed">
              Crafting personalized, highly functional, and beautiful
              residential spaces across Mumbai without the agency markup.
            </p>
          </div>
          <div>
            <h4 class="text-lg font-semibold mb-4 text-gray-200">
              Quick Links
            </h4>
            <ul class="space-y-2">
              <li>
                <a
                  href="/"
                  class="text-gray-400 hover:text-accent text-sm transition-colors"
                  >Home</a>
              </li>
              <li>
                <a
                  href="/spaces"
                  class="text-gray-400 hover:text-accent text-sm transition-colors"
                  >Portfolio Spaces</a>
              </li>
              <li>
                <a
                  href="/work-with-me"
                  class="text-gray-400 hover:text-accent text-sm transition-colors"
                  >Process & Pricing</a>
              </li>
            </ul>
          </div>
          <div>
            <h4 class="text-lg font-semibold mb-4 text-gray-200">Contact</h4>
            <address class="not-italic text-sm text-gray-400 space-y-2">
              <p>Mumbai, Maharashtra, India</p>
              <p>
                Email: <a
                  href="mailto:shabbirtin2001@gmail.com"
                  class="hover:text-accent transition-colors"
                  >shabbirtin2001@gmail.com</a>
              </p>
            </address>
            <div class="mt-6">
              <a
                href="/work-with-me"
                class="inline-block bg-accent hover:bg-accent-hover text-white px-5 py-2.5 rounded text-sm font-medium transition-all transform hover:-translate-y-0.5"
              >
                Get in Touch
              </a>
            </div>
          </div>
        </div>
        <div
          class="border-t border-gray-800 mt-12 pt-8 text-center text-sm text-gray-500 flex flex-col md:flex-row justify-between items-center"
        >
          <p>
            &copy; {new Date().getFullYear()} Shabbir Tinwala Interiors. All rights
            reserved.
          </p>
        </div>
      </div>
    </footer>

    <script>
      // Mobile menu toggle
      const btn = document.getElementById("mobile-menu-btn");
      const menu = document.getElementById("mobile-menu");

      btn?.addEventListener("click", () => {
        menu?.classList.toggle("hidden");
      });

      // Lightbox logic
      const lightbox = document.getElementById("lightbox");
      const lightboxImg = document.getElementById("lightbox-img");
      const lightboxClose = document.getElementById("lightbox-close");

      const images = document.querySelectorAll("img:not(#lightbox-img)");
      images.forEach((img) => {
        img.classList.add(
          "cursor-pointer",
          "transition-transform",
          "hover:opacity-90",
        );
        img.addEventListener("click", () => {
          if (lightbox && lightboxImg) {
            lightboxImg.src = img.src;
            lightboxImg.alt = img.alt || "Expanded image";
            lightbox.classList.remove("hidden");
            lightbox.classList.add("flex");

            setTimeout(() => {
              lightbox.classList.remove("opacity-0");
              lightboxImg.classList.remove("scale-95");
              lightboxImg.classList.add("scale-100");
            }, 10);
          }
        });
      });

      const closeLightbox = () => {
        if (lightbox && lightboxImg) {
          lightbox.classList.add("opacity-0");
          lightboxImg.classList.remove("scale-100");
          lightboxImg.classList.add("scale-95");
          setTimeout(() => {
            lightbox.classList.add("hidden");
            lightbox.classList.remove("flex");
            lightboxImg.src = "";
          }, 300);
        }
      };

      lightboxClose?.addEventListener("click", closeLightbox);
      lightbox?.addEventListener("click", (e) => {
        if (e.target === lightbox) closeLightbox();
      });
      document.addEventListener("keydown", (e) => {
        if (
          e.key === "Escape" &&
          lightbox &&
          !lightbox.classList.contains("hidden")
        ) {
          closeLightbox();
        }
      });
    </script>
  </body>
</html>
